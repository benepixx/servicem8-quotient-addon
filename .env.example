# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Quotient API ─────────────────────────────────────────────────────────────
# Obtain from https://app.quotientapp.com/settings/api
QUOTIENT_API_KEY=your_quotient_api_key_here
QUOTIENT_ACCOUNT_ID=your_quotient_account_id_here

# ── ServiceM8 Job Queues ──────────────────────────────────────────────────────
# The UUIDs of the queues to move jobs into after quote acceptance.
# Find these via: GET https://api.servicem8.com/api_1.0/jobqueue.json
# with an Authorization: Bearer <access_token> header.
SM8_PARTS_TO_ORDER_QUEUE_UUID=
SM8_READY_TO_BOOK_QUEUE_UUID=
